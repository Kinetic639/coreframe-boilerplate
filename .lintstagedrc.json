{
  "apps/web/**/*.{js,jsx,ts,tsx}": [
    "pnpm --filter web exec eslint --fix",
    "pnpm --filter web exec prettier --write"
  ],
  "apps/mobile/**/*.{js,jsx,ts,tsx}": [
    "pnpm --filter mobile exec eslint --fix",
    "pnpm exec prettier --write"
  ],
  "apps/docs/**/*.{js,jsx,ts,tsx}": [
    "pnpm --filter docs exec eslint --fix",
    "pnpm exec prettier --write"
  ],
  "packages/**/*.{js,jsx,ts,tsx,mjs,cjs}": ["pnpm exec prettier --write"],
  "*.{json,md,yml,yaml}": ["pnpm exec prettier --write"]
}
