{
  "name": "web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "supabase:link:legacy": "dotenv -e .env.local -- sh -c 'supabase link --project-ref \"$SUPABASE_LEGACY_PROJECT_REF\"'",
    "supabase:link:target": "dotenv -e .env.local -- sh -c 'supabase --workdir ./supabase-target link --project-ref \"$SUPABASE_TARGET_PROJECT_REF\"'",
    "supabase:migration:new": "dotenv -e .env.local -- sh -c 'supabase migration new'",
    "supabase:migration:new:target": "dotenv -e .env.local -- sh -c 'supabase --workdir ./supabase-target migration new'",
    "supabase:db:push:legacy": "dotenv -e .env.local -- sh -c 'supabase db push --db-url \"$SUPABASE_LEGACY_DB_URL\"'",
    "supabase:db:push:target": "dotenv -e .env.local -- sh -c 'supabase --workdir ./supabase-target db push --db-url \"$SUPABASE_TARGET_DB_URL\"'",
    "supabase:db:push:dry:legacy": "dotenv -e .env.local -- sh -c 'supabase db push --dry-run --db-url \"$SUPABASE_LEGACY_DB_URL\"'",
    "supabase:db:push:dry:target": "dotenv -e .env.local -- sh -c 'supabase --workdir ./supabase-target db push --dry-run --db-url \"$SUPABASE_TARGET_DB_URL\"'",
    "supabase:migration:list:legacy": "dotenv -e .env.local -- sh -c 'supabase migration list --db-url \"$SUPABASE_LEGACY_DB_URL\"'",
    "supabase:migration:list:target": "dotenv -e .env.local -- sh -c 'supabase --workdir ./supabase-target migration list --db-url \"$SUPABASE_TARGET_DB_URL\"'",
    "supabase:gen:types:legacy": "dotenv -e .env.local -- sh -c 'supabase gen types typescript --project-id \"$SUPABASE_LEGACY_PROJECT_REF\" --schema public > supabase/types/legacy.types.ts'",
    "supabase:gen:types:target": "dotenv -e .env.local -- sh -c 'supabase --workdir ./supabase-target gen types typescript --project-id \"$SUPABASE_TARGET_PROJECT_REF\" --schema public > supabase/types/target.types.ts'",
    "supabase:gen:types:runtime": "dotenv -e .env.local -- sh -c 'supabase gen types typescript --project-id \"$SUPABASE_LEGACY_PROJECT_REF\" --schema public > ../../packages/supabase/src/database.types.ts'"
  },
